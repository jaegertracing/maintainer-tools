{
  "extends": "../tsconfig.json",
  // The CLI is run directly from source via `tsx` (see root `triage`
  // script). This tsconfig exists only for the workspace `tsc-lint`
  // typecheck — no emission. Inherits the root's path mappings so
  // `@jaegertracing/maintainer-tools-checks` resolves to source.
  "compilerOptions": {
    "composite": false,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
