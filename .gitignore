# Dependencies and build output
node_modules/
dist/
*.tsbuildinfo
triage.html

# Re-include ncc-bundled action entrypoints. GitHub JS actions ship as
# `action.yml` + a committed `dist/index.js`; that bundle is the artifact users
# pin via `uses: jaegertracing/maintainer-tools/<tool>@vX.Y.Z`.
!pr-nudge/dist/
!pr-nudge/dist/**
!pr-quota/dist/
!pr-quota/dist/**
!pr-weekly-digest/dist/
!pr-weekly-digest/dist/**

# Logs and runtime artifacts
*.log

# Test coverage (reserved for future vitest work)
coverage/
*.lcov

# Local environment / secrets
.env
.env.*
!.env.example

# Local triage CLI artifacts: per-maintainer config and SQLite cache.
.maintainer-tools.json
*.sqlite
*.sqlite-journal

# OS metadata
.DS_Store
