{
  "private": true,
  "name": "@jaegertracing/maintainer-tools",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaegertracing/maintainer-tools.git"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "workspaces": [
    "packages/*",
    "pr-nudge",
    "pr-weekly-digest",
    "cli"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "lint": "npm-run-all -ln --parallel tsc-lint prettier-check",
    "fmt": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\" --log-level warn",
    "prettier-check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\" --log-level warn",
    "tsc-lint": "tsc -p tsconfig.json --noEmit",
    "triage": "tsx cli/src/index.ts triage",
    "test": "npm run --workspaces --if-present test"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@vercel/ncc": "0.38.3",
    "npm-run-all2": "7.0.2",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "6.0.3"
  }
}
