{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "@jaegertracing/maintainer-tools-checks": ["./packages/checks/src/index.ts"],
      "@jaegertracing/maintainer-tools-checks/cache": ["./packages/checks/src/cache.ts"],
      "@jaegertracing/maintainer-tools-checks/comments": [
        "./packages/checks/src/comments/index.ts"
      ],
      "@jaegertracing/maintainer-tools-checks/digest": ["./packages/checks/src/digest.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "pr-nudge/src/**/*",
    "pr-weekly-digest/src/**/*",
    "cli/src/**/*"
  ],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
